<view class="user-page"><view class="card auth-card"><view class="auth-status"><text class="auth-status-label">当前认证状态：</text><text class="{{['auth-status-value', b]}}">{{a}}</text></view><view class="form-item"><text class="form-label">姓名</text><input class="form-input" placeholder="请输入真实姓名" value="{{c}}" bindinput="{{d}}"/></view><view class="form-item"><text class="form-label">学号</text><input class="form-input" placeholder="请输入学号" value="{{e}}" bindinput="{{f}}"/></view><view class="form-item"><text class="form-label">校园邮箱</text><input class="form-input" placeholder="例如 xxx@stu.ecnu.cn" value="{{g}}" bindinput="{{h}}"/></view><view class="tip-text">以上信息仅用于校内身份核验，不会对外展示。</view><button class="btn btn-primary" bindtap="{{i}}">提交认证</button></view></view>