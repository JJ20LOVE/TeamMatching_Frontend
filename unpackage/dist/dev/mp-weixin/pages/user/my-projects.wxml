<view class="user-page"><view wx:if="{{a}}" class="launched-wrapper"><view wx:for="{{b}}" wx:for-item="item" wx:key="b" class="project-card launched-card"><text class="project-title">{{item.a}}</text></view><button class="btn btn-primary create-btn" bindtap="{{c}}"> 创建新项目 </button></view><view wx:elif="{{d}}" class="joined-wrapper"><view wx:for="{{e}}" wx:for-item="item" wx:key="c" class="{{['project-card', 'joined-card', item.d]}}"><view class="joined-main"><text class="project-title">{{item.a}}</text><text class="status-text">{{item.b}}</text></view></view></view><view wx:else class="empty-wrapper"><text class="empty-text">草稿箱暂无内容</text></view></view>